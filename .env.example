# Optional: bake a fal.ai API key into the production build so users don't have
# to provide their own. ⚠️ Anyone with access to the built site can extract this
# key from the bundle — only use for private/local deployments.
VITE_FAL_KEY=

# Optional: override the fal.ai LLM endpoint (default: https://fal.run/fal-ai/any-llm)
VITE_FAL_ENDPOINT=

# Optional: default model used by the any-llm route.
# Examples: google/gemini-flash-1.5-8b, google/gemini-2.5-flash,
# anthropic/claude-3.5-sonnet, anthropic/claude-3.7-sonnet
VITE_FAL_MODEL=google/gemini-flash-1.5-8b
